!sections/product-announcement-bar.liquid

# Full-theme assets (keep product-info-advanced and product-announcement-bar)
assets/
!assets/product-info-advanced.css
!assets/product-info-advanced.js
!assets/product-announcement-bar.css

# Deploy/utility scripts
deploy-log.txt
deploy.ps1
fetch_asset.js
push-restore.js
push.js
