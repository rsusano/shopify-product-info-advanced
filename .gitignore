# This repo tracks only the Product Info Advanced and Product Announcement Bar sections.
# All other EcomLanders theme files are ignored.

# Full theme folders
blocks/
config/
layout/
locales/
snippets/
templates/
tmp-live/

# Full-theme sections (keep product-info-advanced and product-announcement-bar)
sections/
