{%- comment -%} sections/product-announcement-bar.liquid {%- endcomment -%}
{{ 'product-announcement-bar.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign text_color    = section.settings.text_color
  assign bg_color      = section.settings.bg_color
  assign enable_scrolling = section.settings.enable_scrolling
  assign speed         = section.settings.speed

  assign wrapper_classes = 'product-announcement-bar'
  if enable_scrolling
    assign wrapper_classes = wrapper_classes | append: ' product-announcement-bar--scrolling'
  endif
  unless section.settings.show_on_mobile
    assign wrapper_classes = wrapper_classes | append: ' hide-mobile'
  endunless
  unless section.settings.show_on_desktop
    assign wrapper_classes = wrapper_classes | append: ' hide-desktop'
  endunless
-%}

<style>
  #shopify-section-{{ section.id }} {
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    --pab-sep-size: {{ section.settings.separator_size }}px;
    --pab-sep-color: {{ section.settings.separator_color }};
  }
  #shopify-section-{{ section.id }} .product-announcement-bar {
    background-color: {{ bg_color }};
    color: {{ text_color }};
    --scroll-speed: {{ speed }}s;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .product-announcement-bar__text {
    font-size: {{ section.settings.font_size }}px;
    font-weight: {{ section.settings.font_weight }};
    text-transform: {{ section.settings.text_transform }};
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      margin-top: {{ section.settings.mobile_margin_top }}px;
      margin-bottom: {{ section.settings.mobile_margin_bottom }}px;
    }
    #shopify-section-{{ section.id }} .product-announcement-bar {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
    #shopify-section-{{ section.id }} .product-announcement-bar__text {
      font-size: {{ section.settings.mobile_font_size }}px;
    }
  }
</style>

<div class="{{ wrapper_classes }}" data-section-id="{{ section.id }}" data-section-type="product-announcement-bar">
  {%- if section.blocks.size > 0 -%}
    {%- capture announcement_content -%}
      {%- liquid
        assign sep_enable = section.settings.separator_enable
        assign sep_style  = section.settings.separator_style
        assign sep_size   = section.settings.separator_size
      -%}
      <ul class="product-announcement-bar__list">
        {%- for block in section.blocks -%}
          {%- assign text_clean = block.settings.text | replace: '<p>', '' | replace: '</p>', '' | strip -%}
          <li class="product-announcement-bar__item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon_image != blank -%}
              <span class="product-announcement-bar__icon" style="width:{{ block.settings.icon_size }}px;height:{{ block.settings.icon_size }}px;">
                <img src="{{ block.settings.icon_image | image_url: width: 64 }}" alt="" width="{{ block.settings.icon_size }}" height="{{ block.settings.icon_size }}" loading="lazy">
              </span>
            {%- elsif block.settings.icon_svg != blank -%}
              <span class="product-announcement-bar__icon" style="width:{{ block.settings.icon_size }}px;height:{{ block.settings.icon_size }}px;">
                {{ block.settings.icon_svg }}
              </span>
            {%- endif -%}
            {%- if text_clean != blank -%}
              <span class="product-announcement-bar__text">{{ text_clean }}</span>
            {%- endif -%}
          </li>
          {%- unless forloop.last -%}
            {%- if sep_enable -%}
              <li class="product-announcement-bar__separator" aria-hidden="true">
                <span class="product-announcement-bar__sep-icon">
                  {%- case sep_style -%}
                    {%- when 'dot'      -%}&bull;
                    {%- when 'square'   -%}&#9632;
                    {%- when 'pipe'     -%}&#124;
                    {%- when 'star'     -%}&#9733;
                    {%- when 'dash'     -%}&mdash;
                    {%- when 'diamond'  -%}&#9670;
                    {%- when 'triangle' -%}&#9650;
                    {%- when 'custom'   -%}
                      {%- if section.settings.separator_icon_image != blank -%}
                        <img src="{{ section.settings.separator_icon_image | image_url: width: 64 }}"
                             alt="" width="{{ sep_size }}" height="{{ sep_size }}" loading="lazy">
                      {%- elsif section.settings.separator_icon_svg != blank -%}
                        {{ section.settings.separator_icon_svg }}
                      {%- endif -%}
                  {%- endcase -%}
                </span>
              </li>
            {%- endif -%}
          {%- endunless -%}
          {%- if forloop.last and sep_enable and enable_scrolling -%}
            <li class="product-announcement-bar__separator" aria-hidden="true">
              <span class="product-announcement-bar__sep-icon">
                {%- case sep_style -%}
                  {%- when 'dot'      -%}&bull;
                  {%- when 'square'   -%}&#9632;
                  {%- when 'pipe'     -%}&#124;
                  {%- when 'star'     -%}&#9733;
                  {%- when 'dash'     -%}&mdash;
                  {%- when 'diamond'  -%}&#9670;
                  {%- when 'triangle' -%}&#9650;
                  {%- when 'custom'   -%}
                    {%- if section.settings.separator_icon_image != blank -%}
                      <img src="{{ section.settings.separator_icon_image | image_url: width: 64 }}"
                           alt="" width="{{ sep_size }}" height="{{ sep_size }}" loading="lazy">
                    {%- elsif section.settings.separator_icon_svg != blank -%}
                      {{ section.settings.separator_icon_svg }}
                    {%- endif -%}
                {%- endcase -%}
              </span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endcapture -%}

    {%- if enable_scrolling -%}
      <div class="product-announcement-bar__inner" aria-hidden="true">
        {%- for i in (1..8) -%}
          {{ announcement_content }}
        {%- endfor -%}
      </div>
    {%- else -%}
      {{ announcement_content }}
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Product Announcement Bar",
  "class": "section-product-announcement-bar",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#145946"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font Size",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extrabold" }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text Case",
      "options": [
        { "value": "none",       "label": "Original" },
        { "value": "uppercase",  "label": "UPPERCASE" },
        { "value": "lowercase",  "label": "lowercase" },
        { "value": "capitalize", "label": "Capitalize Each Word" }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "mobile_font_size",
      "label": "Font Size (Mobile)",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 11,
      "info": "Applies on screens 768px and below."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "number",
      "id": "margin_top",
      "label": "Margin Top (px)",
      "default": 0,
      "info": "Use a negative value to pull the bar up and reduce the gap above it."
    },
    {
      "type": "number",
      "id": "margin_bottom",
      "label": "Margin Bottom (px)",
      "default": 0,
      "info": "Use a negative value to pull the next section up and reduce the gap below."
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "number",
      "id": "mobile_margin_top",
      "label": "Mobile Margin Top (px)",
      "default": 0,
      "info": "Use a negative value to reduce the gap above on mobile."
    },
    {
      "type": "number",
      "id": "mobile_margin_bottom",
      "label": "Mobile Margin Bottom (px)",
      "default": 0,
      "info": "Use a negative value to reduce the gap below on mobile."
    },
    {
      "type": "header",
      "content": "Separator"
    },
    {
      "type": "checkbox",
      "id": "separator_enable",
      "label": "Show separator between messages",
      "default": true
    },
    {
      "type": "select",
      "id": "separator_style",
      "label": "Separator Style",
      "options": [
        { "value": "dot",      "label": "Dot  •" },
        { "value": "square",   "label": "Square  ■" },
        { "value": "pipe",     "label": "Pipe  |" },
        { "value": "star",     "label": "Star  ★" },
        { "value": "dash",     "label": "Dash  —" },
        { "value": "diamond",  "label": "Diamond  ◆" },
        { "value": "triangle", "label": "Triangle  ▲" },
        { "value": "custom",   "label": "Custom Icon" }
      ],
      "default": "dot"
    },
    {
      "type": "range",
      "id": "separator_size",
      "label": "Separator Size",
      "min": 6,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Custom Separator Icon"
    },
    {
      "type": "image_picker",
      "id": "separator_icon_image",
      "label": "Icon Image"
    },
    {
      "type": "textarea",
      "id": "separator_icon_svg",
      "label": "Icon (SVG code)",
      "info": "Paste raw SVG here. Used only when style is Custom Icon."
    },
    {
      "type": "header",
      "content": "Scrolling"
    },
    {
      "type": "checkbox",
      "id": "enable_scrolling",
      "label": "Enable Scrolling Text",
      "default": false
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scrolling Speed (seconds)",
      "min": 10,
      "max": 60,
      "step": 1,
      "default": 30,
      "info": "Lower is faster."
    },
    {
      "type": "header",
      "content": "Device Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Message",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "info": "Use the editor toolbar to bold or italicise specific words.",
          "default": "<p>LIMITED TIME OFFER - SAVE UP TO 71% OFF</p>"
        },
        {
          "type": "header",
          "content": "Icon (optional)"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "Icon (SVG code)",
          "info": "Paste raw SVG here. Overrides the image if both are set."
        },
        {
          "type": "range",
          "id": "icon_size",
          "label": "Icon Size",
          "min": 12,
          "max": 48,
          "step": 1,
          "unit": "px",
          "default": 16
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Announcement Bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "<p>LIMITED TIME OFFER - SAVE UP TO 71% OFF</p>"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "<p>FREE SHIPPING WORLDWIDE</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
